# Admin Panel
# Password used to log into /admin (used until you set one from the admin UI).
ADMIN_PASSWORD=changeme
# Secret for signing admin session cookies. Use a long random string, stable across restarts.
SESSION_SECRET=please-change-this-to-a-long-random-string

# Notifications can also be edited from the admin UI (stored in the DB).
# The values below are the initial defaults / fallback.

# Email Configuration
EMAIL_ENABLED=false
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=user@example.com
EMAIL_PASS=password
EMAIL_FROM="Status Page" <no-reply@example.com>
EMAIL_TO=admin@example.com

# Google Chat Configuration
GOOGLE_CHAT_ENABLED=false
GOOGLE_CHAT_WEBHOOK_URL=

# MS Teams Configuration
TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=

# Telegram Configuration
# Create a bot with @BotFather to get the token; get your chat ID from @userinfobot.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
